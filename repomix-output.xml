      lowestPriceCurrency: priceSummary.lowestPriceCurrency,
      isFree: priceSummary.isFree
    };
  }),
  facets: {
    categories: [],
    city: [],
    type: []
  },
  meta: {
    found: events.length,
    page: 1,
    perPage: limit,
    engine: 'mongo'
  }
});

