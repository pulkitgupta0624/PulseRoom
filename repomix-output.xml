      - pulseroom
    <<: *dns

  live-service:
    build:
      context: .
      dockerfile: services/live-service/Dockerfile
    environment:
      <<: *backend-env
    depends_on:
      - mongo
      - redis
    networks:
      - pulseroom
    <<: *dns

  admin-service:
    build:
      context: .
      dockerfile: services/admin-service/Dockerfile
    environment:
      <<: *backend-env
    depends_on:
      - mongo
      - redis
    networks:
      - pulseroom
    <<: *dns

  api-gateway:
    build:
      context: .
      dockerfile: api-gateway/Dockerfile
    environment:
      <<: *backend-env
    ports:
      - '8080:8080'
    depends_on:
      - auth-service
      - user-service
      - event-service
      - booking-service
      - chat-service
      - notification-service
      - live-service
      - admin-service
    networks:
      - pulseroom
    <<: *dns

  frontend:
    build:
      context: .
      dockerfile: frontend/Dockerfile
    environment:
      <<: *frontend-env
    ports:
      - '5173:5173'
    depends_on:
      - api-gateway
    networks:
      - pulseroom
    <<: *dns

volumes:
  mongo-data:
  typesense-data:

# ── Named network with explicit driver ───────────────────────────────────────
# Using a named bridge network (instead of the default auto-created one) lets
# Docker Desktop on Windows apply DNS settings consistently across containers.
networks:
  pulseroom:
    driver: bridge
    driver_opts:
      com.docker.network.bridge.name: pulseroom-net
</file>

