# ── Shared DNS config ─────────────────────────────────────────────────────────
# Applied to every service that makes outbound HTTP calls (Cloudinary, Gemini,
# Stripe, SMTP, etc.).  Docker Desktop on Windows often cannot resolve external
# hostnames using the default 127.0.0.11 resolver; pinning to Google Public DNS
# (8.8.8.8 / 8.8.4.4) fixes it.
x-dns: &dns
  dns:
    - 8.8.8.8
    - 8.8.4.4

services:
  mongo:
    image: mongo:7
    container_name: pulseroom-mongo
    ports:
      - '27018:27017'
    volumes:
      - mongo-data:/data/db
    networks:
      - pulseroom

  redis:
    image: redis:7-alpine
    container_name: pulseroom-redis
    ports:
      - '6379:6379'
    networks:
      - pulseroom

  typesense:
    image: typesense/typesense:0.25.2
    container_name: pulseroom-typesense
    command: '--data-dir /data --api-key=pulseroom-typesense-key --enable-cors'
    ports:
      - '8108:8108'
    volumes:
      - typesense-data:/data
    networks:
      - pulseroom

  mailhog:
    image: mailhog/mailhog
    container_name: pulseroom-mailhog
    ports:
      - '8025:8025'
      - '1025:1025'
    networks:
      - pulseroom

  auth-service:
    build:
      context: .
      dockerfile: services/auth-service/Dockerfile
    environment:
      <<: *backend-env
    depends_on:
      - mongo
      - redis
    networks:
      - pulseroom
    <<: *dns

  # user-service makes outbound calls to Cloudinary — DNS is critical here
  user-service:
    build:
      context: .
      dockerfile: services/user-service/Dockerfile
    environment:
      <<: *backend-env
    depends_on:
      - mongo
      - redis
    networks:
      - pulseroom
    <<: *dns

