                        ) : (
                          <>
                            <svg className="h-6 w-6 text-ink/30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                              <path
                                strokeLinecap="round"
                                strokeLinejoin="round"
                                strokeWidth={1.5}
                                d="M12 4v16m8-8H4"
                              />
                            </svg>
                            <p className="text-xs text-ink/40">Upload cover image (optional)</p>
