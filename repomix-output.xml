      default: false,
      index: true
    },
    isActive: {
      type: Boolean,
      default: true,
      index: true
    },
    interests: {
      type: [String],
      default: []
    },
    socialLinks: {
      website: String,
      linkedin: String,
      twitter: String
    },
    organizerProfile: {
      companyName: String,
      website: String,
      supportEmail: String
    },
    location: String,
    lastSeenAt: Date
  },
  {
    timestamps: true
  }
);

userProfileSchema.index({ displayName: 'text', bio: 'text', interests: 'text' });

module.exports = mongoose.model('UserProfile', userProfileSchema);
